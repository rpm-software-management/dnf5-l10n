msgstr ""
"ສະແດງຂໍ້ມູນທີ່ມີປະໂຫຍດກ່ຽວກັບລະບົບ, ມີປະໂຫຍດສຳລັບການກວດສອບຂໍ້ຜິດພາດ (debugging)"

#: copr_disable.cpp:35
#, c++-format
msgid ""
"disable specified Copr repository (if exists), keep {}/*.repo file - just "
"mark enabled=0"
msgstr ""
"ປິດໃຊ້ງານຄັງເກັບ Copr ທີ່ລະບຸ (ຖ້າມີ), ເກັບໄຟລ໌ {}/*.repo ໄວ້ - ພຽງແຕ່ໝາຍໃຫ້ enabled=0"

#: copr_enable.cpp:38
#, c++-format
msgid ""
"download the repository info from a Copr server and install it as a {}/"
"*.repo file"
msgstr "ດາວໂຫຼດຂໍ້ມູນຄັງເກັບຈາກເຊີເວີ Copr ແລະ ຕິດຕັ້ງມັນເປັນໄຟລ໌ {}/*.repo"

#: copr_enable.cpp:46
msgid ""
"Chroot specified in the NAME-RELEASE-ARCH format, e.g. 'fedora-rawhide-"
"ppc64le'.  When not specified, the 'dnf copr' command attempts to detect it."
msgstr ""
"ລະບຸ Chroot ໃນຮູບແບບ NAME-RELEASE-ARCH, ຕົວຢ່າງ: 'fedora-rawhide-ppc64le'. ເມື່ອບໍ່ໄດ້"
"ລະບຸ, ຄຳສັ່ງ 'dnf copr' ຈະພະຍາຍາມກວດຫາດ້ວຍຕົວມັນເອງ."

