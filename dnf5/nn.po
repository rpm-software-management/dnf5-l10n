"No package \"{}\" available; You might want to use --skip-unavailable option."
msgstr ""
"Ingen pakke \"{}\" tilgjengeleg; du kan måtte nytta --skip-unavailable-val."

#: commands/environment/arguments.hpp:33
msgid "Show only available environments."
msgstr "Syn berre tilgjengelege miljø."

#: commands/environment/arguments.hpp:40
msgid "Show only installed environments."
msgstr "Syn berre installerte miljø."

#: commands/environment/arguments.hpp:47
