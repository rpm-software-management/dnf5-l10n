#: commands/advisory/advisory.cpp:36
msgid "Manage advisories"
msgstr "Handter varsel"

#: commands/advisory/advisory_info.hpp:35
msgid "Print details about advisories"
msgstr "Skriv ut detaljar om varsel"

#: commands/advisory/advisory_list.hpp:35
msgid "List advisories"
msgstr "List opp varsel"

#: commands/advisory/advisory_summary.cpp:44
msgid "All"
msgstr "Alle"

#: commands/advisory/advisory_summary.cpp:48
msgid "Installed"
msgstr ""

#: commands/advisory/advisory_summary.cpp:52
msgid "Updates"
msgstr ""

#: commands/advisory/advisory_summary.cpp:65
msgid "Available"
msgstr "Tilgjengeleg"

#: commands/advisory/advisory_summary.hpp:33
msgid "Print summary of advisories"
msgstr "Skriv ut samandrag av varsel"

#: commands/advisory/arguments.hpp:34
msgid "Show advisories containing any version of installed packages."
msgstr "Syn varsel som inneheld nokon versjon av installerte pakkar."

#: commands/advisory/arguments.hpp:45
msgid ""
"Show advisories containing newer versions of installed packages. This is the "
"default behavior."
msgstr ""
"Syn varsel som inneheld nyare versjonar av installerte pakkar. Dette er "
"vanleg åtferd."

#: commands/advisory/arguments.hpp:57
msgid ""
"Show advisories containing equal and older versions of installed packages."
msgstr ""
"Syn varsel som inneheld den same eller eldre versjonar av installerte pakkar."

#: commands/advisory/arguments.hpp:69
msgid ""
"Show advisories containing newer versions of installed packages for which a "
"newer version is available."
msgstr ""
"Syn varsel som inneheld nyare versjonar av installerte pakkar der det finst "
"ein nyare versjon tilgjengeleg."

#: commands/advisory/arguments.hpp:82
msgid ""
"Show only advisories containing packages with specified names. List option, "
"supports globs."
msgstr ""
"Syn berre pakkar som inneheld visse namn. Listealternativ, stør "
"mønsteruttrykk."

#: commands/advisory/arguments.hpp:83 commands/history/arguments.hpp:81
msgid "PACKAGE_NAME,..."
msgstr "PAKKE_NAMN,..."

#: commands/advisory/arguments.hpp:90
msgid "List of patterns matched against advisory names."
msgstr "Liste av mønster som samsvarar med namna på varsla."

#: commands/advisory/arguments.hpp:100
msgid "Show only advisories referencing a bugzilla."
msgstr "Syn berre varsel som refererer til ein bugzilla."

#: commands/advisory/arguments.hpp:107
msgid "Show only advisories referencing a CVE."
msgstr "Syn berre varsel som refererer til ein CVE."

#: commands/advisory_shared.hpp:76
msgid "No advisory found matching the requested name: \"{}\""
msgstr "Inkje varsel funne som samsvarar til det etterspurte namnet: \"{}\""

#: commands/advisory_shared.hpp:109
msgid "No advisory found fixing the Bugzilla ID: \"{}\""
msgstr "Fann inkje varsel som løyser Bugzilla ID-en: \"{}\""

#: commands/advisory_shared.hpp:128
msgid "No advisory found fixing the CVE ID: \"{}\""
msgstr "Fann inkje varsel som løyser CVE ID-en: \"{}\""

#: commands/advisory_shared.hpp:143
msgid "No advisory found matching the specified filters."
msgstr "Fann inkje varsel som samsvarar fastsette filter."

#: commands/advisory_shared.hpp:158
msgid ""
"Include content contained in advisories with specified name. List option."
msgstr "Ta med innhald i varsel med oppgitt namn. Listeval."

#: commands/advisory_shared.hpp:159
msgid "ADVISORY_NAME,..."
msgstr "VARSEL_NAMN,..."

#: commands/advisory_shared.hpp:166
msgid "Include content contained in security advisories."
msgstr "Ta med innhald i tryggingsvarsel."

#: commands/advisory_shared.hpp:173
msgid "Include content contained in bugfix advisories."
msgstr "Ta med innhald i bugfix-varsel."

#: commands/advisory_shared.hpp:180
msgid "Include content contained in enhancement advisories."
msgstr "Ta med innhald i forbetringsvarsel."

#: commands/advisory_shared.hpp:187
msgid "Include content contained in newpackage advisories."
msgstr "Ta med innhald i varsel for nye pakkar."

#: commands/advisory_shared.hpp:198
msgid ""
"Include content contained in advisories with specified severity. List "
"option. Can be \"critical\", \"important\", \"moderate\", \"low\", \"none\"."
msgstr ""
"Ta med innhald i varsel med oppgitt alvorsgrad. Listeval. Kan vera "
"\"kritisk\", \"viktig\", \"moderat\", \"låg\", \"ingen\"."

#: commands/advisory_shared.hpp:200
msgid "ADVISORY_SEVERITY,..."
msgstr "VARSEL_ALVORSGRAD,..."

#: commands/advisory_shared.hpp:212
msgid ""
"Include content contained in advisories that fix a Bugzilla ID, Eg. 123123. "
"List option."
msgstr ""
"Ta med innhald i varsel som retter opp ein Bugzilla-ID, t.d. 123123. "
"Listeval."

#: commands/advisory_shared.hpp:213
msgid "BUGZILLA_ID,..."
msgstr "BUGZILLA_ID,..."

#: commands/advisory_shared.hpp:223
msgid ""
"Include content contained in advisories that fix a CVE (Common "
"Vulnerabilities and Exposures) ID, Eg. CVE-2201-0123. List option."
msgstr ""
"Ta med innhald frå tryggingsvarsel som løyser ein CVE (Common "
"Vulnerabilities and Exposures) ID, t.d. CVE-2201-0123. Listeval."

#: commands/advisory_shared.hpp:225
msgid "CVE_ID,..."
msgstr "CVE_ID,…"

#: commands/autoremove/autoremove.cpp:38
msgid "Remove all unneeded packages originally installed as dependencies."
msgstr "Fjern alle uturvande pakkar som fyrst vart installert som avhengnadar."

#: commands/check-upgrade/check-upgrade.cpp:47
msgid "Check for available package upgrades"
msgstr "Sjå etter tilgjengelege oppgraderingar til pakkar"

#: commands/check-upgrade/check-upgrade.cpp:54
msgid ""
"Reports the lowest versions of packages that fix advisories of type bugfix, "
"enhancement, security, or newpackage. In case that any option limiting "
"advisories is used it reports the lowest versions of packages that fix "
"advisories matching selected advisory properties"
msgstr ""
"Rapporterer dei lægste versjonane av pakkar som løyser tryggingsvarsel av "
"typen feilretting, forbetring, tryggleik eller ny pakke. Dersom det vert "
"nytta eit alternativ som avgrensar tryggingsvarsla, rapporterast dei lægste "
"versjonane av pakkar som løyser tryggingsvarsel som samsvarar med dei valte "
"eigenskapane for tryggingsvarsla"

#: commands/check/check.cpp:247
msgid "Check for problems in the packagedb"
msgstr "Sjå etter problem i packagedb"

#: commands/check/check.cpp:335
msgid "Check discovered {} problem(s) in {} package(s)"
msgstr "Sjå etter oppdaga {} problem i {} pakke(pakkar)"

