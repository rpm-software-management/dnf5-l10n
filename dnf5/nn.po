#: commands/environment/environment.cpp:35
msgid "Manage comps environments"
msgstr "Handter comps-miljø"

#: commands/from_repo.cpp:35
msgid ""
"The following items can be selected only from the specified repositories. "
"All enabled repositories will still be used to satisfy dependencies."
msgstr ""
"Fylgjande element kan berre verta valt frå oppgjevne pakkebrunnar. Alle "
"aktiverte pakkebrunnar vil fortsatt verta brukt til å oppfylle avhengnadar."

#: commands/from_repo.cpp:38 commands/from_repo.cpp:70
msgid "REPO_ID,..."
msgstr "REPO_ID,..."

#: commands/from_repo.cpp:53
msgid "\"--from_repo\" already defined with diferent value"
msgstr "\"--from_repo\" er alt definert med ein annan verdi"

#: commands/from_repo.cpp:68
msgid ""
"Filters installed packages by the ID of the repository they were installed "
"from."
msgstr ""
"Filtrerar installerte pakkar etter ID-en til pakkebrunnen dei vart "
"installert frå."

#: commands/from_repo.cpp:79
msgid "\"--installed-from_repo\" already defined with diferent value"
msgstr "\"--installed-from_repo\" er alt definert med ein annan verdi"

#: commands/group/arguments.hpp:34
msgid "Show only available groups."
msgstr "Syn berre tilgjengelege grupper."

#: commands/group/arguments.hpp:41
msgid "Show also hidden groups."
msgstr "Syn også skylte grupper."

#: commands/group/arguments.hpp:48
msgid "Show only installed groups."
msgstr "Syn berre installerte grupper."

#: commands/group/arguments.hpp:59
msgid ""
"Show only groups containing packages with specified names. List option, "
"supports globs."
msgstr ""
"Syn berre grupper som inneheld pakkar med oppgjevne namn. Listeval, stør "
"globs."

#: commands/group/arguments.hpp:67
msgid "Pattern matching group IDS."
msgstr "Gruppe-ID-ar som samsvarar med mønsteret."

#: commands/group/arguments.hpp:76
msgid "Include optional packages from group."
msgstr "Ta med valfrie pakkar frå gruppe."

#: commands/group/arguments.hpp:83
msgid "Operate on groups only, no packages are changed."
msgstr "Operer berre på grupper, ingen pakkar vert brigda."

#: commands/history/arguments.hpp:37
msgid "Transaction ID"
msgstr "Transaksjons-ID"

#: commands/history/arguments.hpp:44
msgid "Reverse the order of transactions."
msgstr "Vend om rekkefylgja til transaksjonar."

#: commands/history/arguments.hpp:54
msgid ""
"Don't consider mismatches between installed and stored transaction packages "
"as errors. This can result in an empty transaction because among other "
"things the option can ignore failing Remove actions."
msgstr ""
"Ikkje sjå på avvik mellom installerte og lagra transaksjonspakkar som feil. "
"Dette kan føra til ein tom transaksjon fordi valet, mellom anna, kan "
"ignorera mislukka Remove-handlingar."

#: commands/history/arguments.hpp:67
msgid "Don't consider extra packages pulled into the transaction as errors."
msgstr "Ikkje sjå på tilleggspakkar som er inkludert i transaksjonen som feil."

#: commands/history/arguments.hpp:80
msgid ""
"Show only transactions containing packages with specified names. List "
"option, supports globs."
msgstr ""
"Syn berre transaksjonar som inneheld pakkar med oppgjevne namn. Listeval, "
"stør globs."

#: commands/history/history.cpp:41
msgid "Manage transaction history"
msgstr "Handter transaksjonshistorikk"

#: commands/history/history_info.cpp:70
msgid ""
"No match found, history info defaults to considering only the last "
"transaction, specify \"1..last\" range to search all transactions."
msgstr ""
"Fann ingen treff. Historikkinfo reknar som standard berre med den siste "
"transaksjonen. Spesifiser området «1..last» for å søkja i alle transaksjonar."

#: commands/history/history_redo.cpp:54
#: commands/history/history_rollback.cpp:58
#: commands/history/history_store.cpp:65 commands/history/history_undo.cpp:57
msgid "No matching transaction ID found, exactly one required."
msgstr "Ingen samsvarande transaksjons-ID funne. Akkurat ein vert kravd."

#: commands/history/history_redo.cpp:58
#: commands/history/history_rollback.cpp:62
#: commands/history/history_undo.cpp:61
msgid "Matched more than one transaction ID, exactly one required."
msgstr "Svara til meir enn éin transaksjons-ID. Akkurat éin vert kravd."

#: commands/history/history_store.cpp:68
msgid "Multiple transactions selected for storing, only one allowed."
msgstr "Fleire transaksjonar valt til å lagra, berre éin mogleg om gangen."

#: commands/history/history_store.cpp:80
msgid "File \"{}\" already exists, it will be overwritten.\n"
msgstr "Fila \"{}\" finst alt, ho vil verta overskriven.\n"

#: commands/history/transaction_id.cpp:32
msgid ""
"Invalid transaction ID range \"{}\", \"ID\" or \"ID..ID\" expected, where ID "
"is \"NUMBER\", \"last\" or \"last-NUMBER\"."
msgstr ""
"Ugild område for transaksjons-ID «{}». Venta «ID» eller «ID..ID», der ID er «"
"NUMMER», «last» eller «last-NUMMER»."

#: commands/install/install.cpp:43
msgid "Install software"
msgstr "Installer programvare"

#: commands/leaves/leaves.cpp:42
msgid ""
"List groups of installed packages not required by other installed packages"
msgstr ""
"List opp grupper av installerte pakkar som ikkje krevst av andre installerte "
"pakkar"

#: commands/list/list.cpp:46
msgid "Lists packages depending on the packages' relation to the system"
msgstr "Listar opp pakkar som avheng av pakkane sin relasjon til systemet"

#: commands/list/list.cpp:50
msgid "List of package-spec-NI to match (case insensitively)"
msgstr ""
"Liste over package-spec-NI som skal samsvara (skil ikkje mellom store og små "
"bokstavar)"

#: commands/list/list.cpp:62
msgid "Show all versions of the packages, not only the latest ones."
msgstr "Syn alle versjonar av pakken, ikkje berre dei nyaste."

#: commands/list/list.cpp:70
msgid "List installed packages."
msgstr "List opp installerte pakkar."

#: commands/list/list.cpp:74
msgid "List available packages."
msgstr "List opp tilgjengelege pakkar."

#: commands/list/list.cpp:81
msgid ""
"List extras, that is packages installed on the system that are not available "
"in any known repository."
msgstr ""
"Syn tillegg («extras»), det vil seia pakkar installerte på systemet som "
"ikkje er tilgjengelege i nokon kjend pakkebrunn."

#: commands/list/list.cpp:89
msgid ""
