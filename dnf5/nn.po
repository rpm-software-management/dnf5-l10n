#: commands/clean/clean.cpp:176
msgid "Cache directory \"{}\" does not exist. Nothing to clean."
msgstr "Cache-katalog \"{}\" finst ikkje. Ingenting å rydde opp i."

#: commands/clean/clean.cpp:181
msgid "Cannot iterate cache directory \"{}\": {}"
msgstr "Kan ikkje gjennomsøkja cache-katalogen \"{}\": {}"

