#: commands/advisory/advisory.cpp:36
msgid "Manage advisories"
msgstr "ຈັດການແຈ້ງການ (advisories)"

#: commands/advisory/advisory_info.hpp:35
msgid "Print details about advisories"
msgstr "ສະແດງລາຍລະອຽດກ່ຽວກັບແຈ້ງການ"

#: commands/advisory/advisory_list.hpp:35
msgid "List advisories"
msgstr "ສະແດງລາຍຊື່ແຈ້ງການ"

#: commands/advisory/advisory_summary.cpp:44
msgid "All"
msgstr "ທັງໝົດ"

#: commands/advisory/advisory_summary.cpp:48
msgid "Installed"
msgstr "ຕິດຕັ້ງແລ້ວ"

#: commands/advisory/advisory_summary.cpp:52
msgid "Updates"
msgstr "ອັບເດດ"

#: commands/advisory/advisory_summary.cpp:65
msgid "Available"
msgstr "ທີ່ມີໃຫ້ໃຊ້"

#: commands/advisory/advisory_summary.hpp:33
msgid "Print summary of advisories"
msgstr "ສະແດງບົດສະຫຼຸບຂອງແຈ້ງການ"

#: commands/advisory/arguments.hpp:34
msgid "Show advisories containing any version of installed packages."
msgstr "ສະແດງແຈ້ງການທີ່ມີທຸກເວີຊັນຂອງແພັກເກດທີ່ຕິດຕັ້ງແລ້ວ."

#: commands/advisory/arguments.hpp:45
msgid ""
"Show advisories containing newer versions of installed packages. This is the "
"default behavior."
msgstr ""
"ສະແດງແຈ້ງການທີ່ມີເວີຊັນໃໝ່ກວ່າຂອງແພັກເກດທີ່ຕິດຕັ້ງແລ້ວ. ນີ້ແມ່ນຄ່າເລີ່ມຕົ້ນ."

#: commands/advisory/arguments.hpp:57
msgid ""
"Show advisories containing equal and older versions of installed packages."
msgstr "ສະແດງແຈ້ງການທີ່ມີເວີຊັນດຽວກັນ ຫຼື ເກົ່າກວ່າຂອງແພັກເກດທີ່ຕິດຕັ້ງແລ້ວ."

#: commands/advisory/arguments.hpp:69
msgid ""
"Show advisories containing newer versions of installed packages for which a "
"newer version is available."
msgstr ""
"ສະແດງແຈ້ງການທີ່ມີເວີຊັນໃໝ່ກວ່າຂອງແພັກເກດທີ່ຕິດຕັ້ງແລ້ວ ເຊິ່ງມີເວີຊັນໃໝ່ກວ່າມີໃຫ້ໃຊ້."

#: commands/advisory/arguments.hpp:82
msgid ""
"Show only advisories containing packages with specified names. List option, "
"supports globs."
msgstr ""
"ສະແດງສະເພາະແຈ້ງການທີ່ມີແພັກເກດຕາມຊື່ທີ່ລະບຸ. ເປັນຕົວເລືອກແບບລາຍຊື່, ຮອງຮັບ globs."

#: commands/advisory/arguments.hpp:83 commands/history/arguments.hpp:81
msgid "PACKAGE_NAME,..."
msgstr "ຊື່ແພັກເກດ,..."

#: commands/advisory/arguments.hpp:90
msgid "List of patterns matched against advisory names."
msgstr "ລາຍຊື່ຮູບແບບ (patterns) ທີ່ກົງກັບຊື່ແຈ້ງການ."

#: commands/advisory/arguments.hpp:100
msgid "Show only advisories referencing a bugzilla."
msgstr "ສະແດງສະເພາະແຈ້ງການທີ່ອ້າງອີງເຖິງ bugzilla."

#: commands/advisory/arguments.hpp:107
msgid "Show only advisories referencing a CVE."
msgstr "ສະແດງສະເພາະແຈ້ງການທີ່ອ້າງອີງເຖິງ CVE."

#: commands/advisory_shared.hpp:76
#, c++-format
msgid "No advisory found matching the requested name: \"{}\""
msgstr "ບໍ່ພົບແຈ້ງການທີ່ກົງກັບຊື່ທີ່ຮ້ອງຂໍ: \"{}\""

#: commands/advisory_shared.hpp:109
#, c++-format
msgid "No advisory found fixing the Bugzilla ID: \"{}\""
msgstr "ບໍ່ພົບແຈ້ງການທີ່ແກ້ໄຂ Bugzilla ID: \"{}\""

#: commands/advisory_shared.hpp:128
#, c++-format
msgid "No advisory found fixing the CVE ID: \"{}\""
msgstr "ບໍ່ພົບແຈ້ງການທີ່ແກ້ໄຂ CVE ID: \"{}\""

#: commands/advisory_shared.hpp:143
msgid "No advisory found matching the specified filters."
msgstr "ບໍ່ພົບແຈ້ງການທີ່ກົງກັບຕົວຕອງທີ່ລະບຸ."

#: commands/advisory_shared.hpp:158
msgid ""
"Include content contained in advisories with specified name. List option."
msgstr "ລວມເນື້ອໃນທີ່ມີຢູ່ໃນແຈ້ງການຕາມຊື່ທີ່ລະບຸ. ເປັນຕົວເລືອກແບບລາຍຊື່."

#: commands/advisory_shared.hpp:159
msgid "ADVISORY_NAME,..."
msgstr "ຊື່ແຈ້ງການ,..."

#: commands/advisory_shared.hpp:166
msgid "Include content contained in security advisories."
msgstr "ລວມເນື້ອໃນທີ່ມີຢູ່ໃນແຈ້ງການດ້ານຄວາມປອດໄພ."

#: commands/advisory_shared.hpp:173
msgid "Include content contained in bugfix advisories."
msgstr "ລວມເນື້ອໃນທີ່ມີຢູ່ໃນແຈ້ງການແກ້ໄຂບັກ (bugfix)."

#: commands/advisory_shared.hpp:180
msgid "Include content contained in enhancement advisories."
msgstr "ລວມເນື້ອໃນທີ່ມີຢູ່ໃນແຈ້ງການເພີ່ມປະສິດທິພາບ (enhancement)."

#: commands/advisory_shared.hpp:187
msgid "Include content contained in newpackage advisories."
msgstr "ລວມເນື້ອໃນທີ່ມີຢູ່ໃນແຈ້ງການແພັກເກດໃໝ່ (newpackage)."

#: commands/advisory_shared.hpp:198
msgid ""
"Include content contained in advisories with specified severity. List "
"option. Can be \"critical\", \"important\", \"moderate\", \"low\", \"none\"."
msgstr ""
"ລວມເນື້ອໃນທີ່ມີຢູ່ໃນແຈ້ງການຕາມລະດັບຄວາມຮຸນແຮງທີ່ລະບຸ. ສາມາດເປັນ \"critical\", "
"\"important\", \"moderate\", \"low\", \"none\"."

