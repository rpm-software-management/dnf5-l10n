#: actions.cpp:237
#, c++-format
msgid "File \"{}\" on line {}: {}"
msgstr "ໄຟລ໌ \"{}\" ຢູ່ແຖວທີ {}: {}"

#: actions.cpp:636 actions.cpp:642 actions.cpp:648 actions.cpp:654
msgid "\"HOOK:PKG_FILTER:DIRECTION:OPTIONS:CMD\" format expected"
msgstr "ຕ້ອງການຮູບແບບ \"HOOK:PKG_FILTER:DIRECTION:OPTIONS:CMD\""

#: actions.cpp:676
#, c++-format
msgid "Unknown \"enabled\" option value \"{}\""
msgstr "ບໍ່ຮູ້ຈັກຄ່າຂອງຕົວເລືອກ \"enabled\" \"{}\""

#: actions.cpp:683
#, c++-format
msgid "Unknown option \"{}\""
msgstr "ບໍ່ຮູ້ຈັກຕົວເລືອກ \"{}\""

#: actions.cpp:711
#, c++-format
msgid "Unknown hook \"{}\""
msgstr "ບໍ່ຮູ້ຈັກ hook \"{}\""

#: actions.cpp:720
msgid ""
"Package filter can only be used in GOAL_RESOLVED, PRE_TRANS and POST_TRANS "
"hooks"
msgstr ""
"ຕົວຕອງແພັກເກດສາມາດໃຊ້ໄດ້ສະເພາະໃນ hook GOAL_RESOLVED, PRE_TRANS ແລະ POST_TRANS ເທົ່າ"
"ນັ້ນ"

#: actions.cpp:726
msgid "Cannot use direction without package filter"
msgstr "ບໍ່ສາມາດໃຊ້ທິດທາງ (direction) ໂດຍບໍ່ມີຕົວຕອງແພັກເກດ"

#: actions.cpp:740
#, c++-format
msgid "Unknown package direction \"{}\""
msgstr "ບໍ່ຮູ້ຈັກທິດທາງແພັກເກດ \"{}\""

#: actions.cpp:747
#, c++-format
msgid "Unknown mode \"{}\""
msgstr "ບໍ່ຮູ້ຈັກໂໝດ \"{}\""

#: actions.cpp:755
#, c++-format
msgid "Unsupported value of the \"raise_error\" option: {}"
msgstr "ຄ່າຂອງຕົວເລືອກ \"raise_error\" ບໍ່ຮອງຮັບ: {}"

#: actions.cpp:760
msgid "Missing command"
msgstr "ຄຳສັ່ງຫາຍໄປ"

#: actions.cpp:953
#, c++-format
msgid "Synax error: Missing equal sign (=) in action output line: {}"
msgstr "ໄວຍາກອນຜິດພາດ: ເຄື່ອງໝາຍເທົ່າກັບ (=) ຫາຍໄປໃນແຖວຜົນອອກຂອງການກະທຳ: {}"

#: actions.cpp:964
#, c++-format
msgid "Cannot set option: Action output line: {}"
msgstr "ບໍ່ສາມາດຕັ້ງຕົວເລືອກ: ແຖວຜົນອອກຂອງການກະທຳ: {}"

#: actions.cpp:982
#, c++-format
msgid "Action sent the wrong log level: {}"
msgstr "ການກະທຳສົ່ງລະດັບບັນທຶກ (log level) ທີ່ບໍ່ຖືກຕ້ອງ: {}"

#: actions.cpp:987 actions.cpp:1794
#, c++-format
msgid "Action calls for stop: {}"
msgstr "ການກະທຳຮ້ອງຂໍໃຫ້ຢຸດ: {}"

#: actions.cpp:990 actions.cpp:1801
#, c++-format
msgid "Action sent error message: {}"
msgstr "ການກະທຳສົ່ງຂໍ້ຄວາມຂໍ້ຜິດພາດ: {}"

#: actions.cpp:995
#, c++-format
msgid ""
"Syntax error: Action output line must start with \"tmp.\" or \"conf.\" or "
"\"var.\" or \"stop=\" or \"error=\": {}"
msgstr ""
"ໄວຍາກອນຜິດພາດ: ແຖວຜົນອອກຂອງການກະທຳຕ້ອງເລີ່ມຕົ້ນດ້ວຍ \"tmp.\" ຫຼື \"conf.\" ຫຼື \"var.\" "
"ຫຼື \"stop=\" ຫຼື \"error=\": {}"

#: actions.cpp:1020
msgid "Error reading from action (from pipe)"
msgstr "ເກີດຂໍ້ຜິດພາດໃນການອ່ານຈາກການກະທຳ (ຈາກ pipe)"

#: actions.cpp:1038
#, c++-format
msgid "Syntax error in json request from action: Missing starting '{{' char"
msgstr "ໄວຍາກອນຜິດພາດໃນການຮ້ອງຂໍ json ຈາກການກະທຳ: ຕົວອັກສອນເລີ່ມຕົ້ນ '{{' ຫາຍໄປ"

#: actions.cpp:1062
msgid "Error during processing of a request from action."
msgstr "ເກີດຂໍ້ຜິດພາດໃນລະຫວ່າງການປະມວນຜົນການຮ້ອງຂໍຈາກການກະທຳ."

#: actions.cpp:1071
#, c++-format
msgid "Syntax error in json request from action: {}"
msgstr "ໄວຍາກອນຜິດພາດໃນການຮ້ອງຂໍ json ຈາກການກະທຳ: {}"

#: actions.cpp:1079
msgid "Syntax error in json request from action: Incomplete input"
msgstr "ໄວຍາກອນຜິດພາດໃນການຮ້ອງຂໍ json ຈາກການກະທຳ: ຂໍ້ມູນຂາເຂົ້າບໍ່ສົມບູນ"

#: actions.cpp:1154
msgid "Cannot write response"
msgstr "ບໍ່ສາມາດຂຽນການຕອບກັບ"

#: actions.cpp:1821
msgid "Actions plugin: Cannot create pipe"
msgstr "ປລັກອິນການກະທຳ: ບໍ່ສາມາດສ້າງ pipe"

#: actions.cpp:1913
msgid "Actions plugin: Cannot fork"
msgstr "ປລັກອິນການກະທຳ: ບໍ່ສາມາດ fork"

#: actions.cpp:1968
msgid "Actions plugin: Cannot bind command stdin"
msgstr "ປລັກອິນການກະທຳ: ບໍ່ສາມາດຜູກມັດ stdin ຂອງຄຳສັ່ງ"

#: actions.cpp:1970
msgid "Actions plugin: Cannot bind command stdout"
msgstr "ປລັກອິນການກະທຳ: ບໍ່ສາມາດຜູກມັດ stdout ຂອງຄຳສັ່ງ"

#: actions.cpp:1988
#, c++-format
msgid "Cannot execute action, command \"{}\" arguments \"{}\""
msgstr "ບໍ່ສາມາດປະຕິບັດການກະທຳ, ຄຳສັ່ງ \"{}\" ພ້ອມອາກິວເມັນ \"{}\""

#: actions.cpp:1996
msgid "Error during preparation child process"
msgstr "ເກີດຂໍ້ຜິດພາດໃນລະຫວ່າງການກຽມໂປຣເຊສລູກ (child process)"

#: actions.cpp:2015
#, c++-format
msgid "Exit code: {}"
msgstr "ລະຫັດອອກ (Exit code): {}"

#: actions.cpp:2019
#, c++-format
msgid "Terminated by signal: {}"
msgstr "ຖືກຢຸດໂດຍສັນຍານ (signal): {}"
